<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/hacker_card_bg"
    android:padding="12dp"
    android:layout_margin="4dp">

    <!-- Main host info row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Status indicator -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/status_indicator_green" />

        <!-- IP and MAC -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvIpAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="192.168.1.1"
                android:textColor="@color/neon_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvMacAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAC: 00:11:22:33:44:55"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Port count and latency -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvPortCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 ports"
                android:textColor="@color/cyber_pink"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23ms"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Expand arrow -->
        <ImageView
            android:id="@+id/btnExpand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/arrow_down_float"
            android:contentDescription="Expand"
            app:tint="@color/neon_green"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Expanded details section -->
    <LinearLayout
        android:id="@+id/expandedDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:paddingTop="12dp"
        android:background="@color/terminal_gray">

        <!-- OS Guess -->
        <TextView
            android:id="@+id/tvOsGuess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OS: Linux 4.x"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <!-- Open Ports Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPEN PORTS:"
            android:textColor="@color/neon_green"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Ports list -->
        <LinearLayout
            android:id="@+id/portsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Vendor info -->
        <TextView
            android:id="@+id/tvVendor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vendor: Unknown"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</LinearLayout>
