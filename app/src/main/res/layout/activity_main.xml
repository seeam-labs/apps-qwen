<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".ui.MainActivity">

    <!-- Header with device info -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/header_bg"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/neon_green"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1" />

        <!-- Device Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ip_address"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvIpAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mac_address"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvMacAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Root Status Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/root_status"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvRootStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHECKING..."
                    android:textColor="@color/hacker_yellow"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:background="@drawable/terminal_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Main content - Grid of scan cards -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/terminalLayout">

        <GridLayout
            android:id="@+id/cardsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:padding="12dp"
            android:alignmentMode="alignMargins">

            <!-- Quick Scan Card -->
            <LinearLayout
                android:id="@+id/cardQuickScan"
                style="@style/ScanCardButton"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_scan"
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ping + Port Scan"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Network Mapper Card -->
            <LinearLayout
                android:id="@+id/cardNetworkMapper"
                style="@style/ScanCardButton"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/network_mapper"
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subnet Discovery"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Vulnerability Audit Card -->
            <LinearLayout
                android:id="@+id/cardVulnAudit"
                style="@style/ScanCardButton"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vulnerability_audit"
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Banner Grabbing"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Packet Injector Card (Root Only) -->
            <LinearLayout
                android:id="@+id/cardPacketInjector"
                style="@style/ScanCardButton"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/scan_card_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💉"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/packet_injector"
                    android:textColor="@color/cyber_pink"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROOT REQUIRED"
                    android:textColor="@color/hacker_red"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Wi-Fi Analyzer Card -->
            <LinearLayout
                android:id="@+id/cardWifiAnalyzer"
                style="@style/ScanCardButton"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📶"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_analyzer"
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Signal & Channels"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Saved Profiles Card -->
            <LinearLayout
                android:id="@+id/cardSavedProfiles"
                style="@style/ScanCardButton"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📁"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/saved_profiles"
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Load/Save Scans"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </GridLayout>
    </ScrollView>

    <!-- Terminal Log at bottom -->
    <LinearLayout
        android:id="@+id/terminalLayout"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:orientation="vertical"
        android:background="@drawable/terminal_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:background="@color/terminal_gray">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="> TERMINAL_LOG"
                android:textColor="@color/neon_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[CLEAR]"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/terminalScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <TextView
                android:id="@+id/terminalOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="> ZenMap Pro Ultra v1.0.0\n> Initializing system...\n> Waiting for commands...\n"
                android:textColor="@color/neon_green"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:padding="12dp"
                android:scrollbars="vertical" />
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
