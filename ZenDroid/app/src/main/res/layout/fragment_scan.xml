<?xml version="1.0" encoding="utf-8"?>
<fragment xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scan_fragment"
    android:name="com.zendroid.nmapgui.ui.fragment.ScanFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Command Preview -->
        <TextView
            android:id="@+id/command_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/terminal_green"
            android:textSize="12sp"
            android:background="@color/cyber_surface"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Target Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/target_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/scan_target_hint"
            app:boxStrokeColor="@color/neon_cyan"
            app:hintTextColor="@color/neon_cyan"
            app:layout_constraintTop_toBottomOf="@id/command_preview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/target_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Profile Spinner -->
        <Spinner
            android:id="@+id/profile_spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/cyber_surface"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/target_input_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Scan Options -->
        <ScrollView
            android:id="@+id/options_scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/profile_spinner"
            app:layout_constraintBottom_toTopOf="@id/start_scan_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <CheckBox
                    android:id="@+id/chk_service_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-sV Service Version Detection"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/chk_os_detection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-O OS Detection (requires root)"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/chk_script_scan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-sC Default Scripts"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/chk_aggressive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-A Aggressive Mode"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/chk_no_ping"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-Pn No Ping"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </ScrollView>

        <!-- Start Scan Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_scan_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/start_scan"
            android:textSize="16sp"
            app:backgroundTint="@color/neon_cyan"
            app:cornerRadius="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</fragment>
