APP_NAME=NexaMarket
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://nexamarket.test
APP_TIMEZONE=UTC

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexamarket
DB_USERNAME=root
DB_PASSWORD=

# Queue (use database for shared hosting compatibility)
QUEUE_CONNECTION=database

# Storage — Cloudflare R2
FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=nexamarket-products
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# Fallback: local storage during development
# FILESYSTEM_DISK=local

# Mail
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@nexamarket.com
MAIL_FROM_NAME="${APP_NAME}"

# AI Services (optional — features degrade gracefully)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
VIRUSTOTAL_API_KEY=

# Search (optional — falls back to MySQL if not set)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Payment (Stripe)
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=

# Business Rules
PLATFORM_COMMISSION_RATE=30
MINIMUM_WITHDRAWAL_AMOUNT=50
WITHDRAWAL_FEE_PERCENTAGE=2

# Security
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
